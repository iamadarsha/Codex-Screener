{
  "name": "breakoutscan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "start:web": "npm --prefix apps/web run start",
    "lint:web": "npm --prefix apps/web run lint",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "dev:mobile": "npm --prefix apps/mobile run start",
    "typecheck:mobile": "npm --prefix apps/mobile run typecheck",
    "test:api": "python3 -m pytest apps/api/app/tests",
    "up": "docker compose up --build",
    "down": "docker compose down"
  }
}

